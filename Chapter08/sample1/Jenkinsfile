pipeline {
    agent any

    stages {

        stage('Branch Validation') {
            steps {
                script {
                    if (env.BRANCH_NAME == 'master') {
                        echo "Master branch detected"
                    }
                    else if (env.BRANCH_NAME.contains('feature')) {
                        echo "Feature branch detected"
                    }
                    else {
                        error("Invalid branch name: ${env.BRANCH_NAME}. Only 'master' or branches containing 'feature' are allowed.")
                    }
                }
            }
        }

        stage('Prepare') {
            steps {
                sh '''
                    cd Chapter08/sample1
                    chmod +x gradlew
                '''
            }
        }

        stage('Clean') {
            steps {
                sh '''
                    cd Chapter08/sample1
                    ./gradlew clean
                '''
            }
        }

        stage('Run Tests') {
            when {
                anyOf {
                    branch 'master'
                    expression {
                        env.BRANCH_NAME.contains('feature')
                    }
                }
            }
            steps {
                sh '''
                    cd Chapter08/sample1
                    ./gradlew test
                '''
            }
        }

        stage('Code Coverage') {
            when {
                branch 'master'
            }
            steps {
                sh '''
                    cd Chapter08/sample1
                    ./gradlew jacocoTestCoverageVerification
                '''
            }
        }

        stage('Checkstyle') {
            when {
                anyOf {
                    branch 'master'
                    expression {
                        env.BRANCH_NAME.contains('feature')
                    }
                }
            }
            steps {
                sh '''
                    cd Chapter08/sample1
                    ./gradlew checkstyleMain
                '''
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: 'Chapter08/sample1/build/reports/checkstyle',
                        reportFiles: 'main.html',
                        reportName: 'Checkstyle Report'
                    ])
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully."
        }

        failure {
            echo "Pipeline failed."
        }

        always {
            echo "Branch: ${env.BRANCH_NAME}"
        }
    }
}