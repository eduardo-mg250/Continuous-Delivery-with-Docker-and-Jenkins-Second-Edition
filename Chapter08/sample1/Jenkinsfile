pipeline {
  agent any
  stages {
    stage('Clean') {
      steps {
        sh "./gradlew clean"
      }
    }
    stage('Run Tests') {
      steps {
        sh "./gradlew test"
      }
    }
    stage('Code Coverage') {
      steps {
        sh "./gradlew jacocoTestCoverageVerification"
      }
    }
    
stage('Checkstyle') {
  steps {
    sh "./gradlew checkstyleMain"
  }
  post {
    always {
      publishHTML(target: [
        reportDir: 'build/reports/checkstyle',
        reportFiles: 'main.html',
        reportName: "jacoco checkstyle"
      ])
    }
  }
}

    
  }
}
