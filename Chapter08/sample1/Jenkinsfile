pipeline {
    agent {
        label 'gradle'
    }

    stages {

        stage('Prepare') {
            steps {
                sh '''
                    cd Chapter08/sample1
                    chmod +x gradlew
                '''
            }
        }

        stage('Clean') {
            steps {
                sh '''
                    cd Chapter08/sample1
                    sh gradlew clean
                '''
            }
        }

        stage('Run Tests') {

            steps {
                script {
                    try {

                        sh '''
                            cd Chapter08/sample1
                            sh gradlew test
                        '''

                        echo "tests pass!"

                    } catch (Exception e) {

                        echo "tests fail!"
                        throw e

                    } finally {

                        sh '''
                            cd Chapter08/sample1

                            sh gradlew jacocoTestReport || true

                            find build -name index.html || true
                        '''
                    }
                }
            }
        }

        stage('Code Coverage') {

            when {
                branch 'master'
            }

            steps {
                sh '''
                    cd Chapter08/sample1
                    sh gradlew jacocoTestCoverageVerification
                '''
            }
        }

        stage('Checkstyle') {

            steps {
                sh '''
                    cd Chapter08/sample1
                    sh gradlew checkstyleMain
                '''
            }

            post {
                always {
                    publishHTML(target: [
                        reportDir: 'Chapter08/sample1/build/reports/checkstyle',
                        reportFiles: 'main.html',
                        reportName: 'Checkstyle Report',
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true
                    ])
                }
            }
        }
    }

    post {

        success {
            echo "Pipeline completed successfully."
        }

        failure {
            echo "Pipeline failed."
        }

        always {

            script {

                if (fileExists('Chapter08/sample1/build/reports/jacoco/test/html/index.html')) {

                    publishHTML(target: [
                        reportDir: 'Chapter08/sample1/build/reports/jacoco/test/html',
                        reportFiles: 'index.html',
                        reportName: 'JaCoCo Report',
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true
                    ])

                } else {

                    echo "JaCoCo report was not generated."
                }
            }

            echo "Branch: ${env.BRANCH_NAME}"
        }
    }
}
