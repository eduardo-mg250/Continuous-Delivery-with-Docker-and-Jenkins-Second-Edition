pipeline {
    agent {
        label 'gradle'
    }
    stages {

        stage('Agent Info') {
    steps {
        sh '''
            cat /etc/os-release || true
            hostname
            whoami
            gradle --version || true
        '''
    }
}

        stage('Agent Verification') {
    steps {
        sh '''
            whoami
            hostname
            java -version
            gradle --version
            pwd
        '''
    }
}

        stage('Prepare') {
            steps {
                sh '''
                    cd Chapter08/sample1
                    chmod +x gradlew
                '''
            }
        }

       stage('Clean') {
    steps {
        sh '''
            cd Chapter08/sample1
            pwd
            ls -l
            chmod +x gradlew
            ls -l gradlew
            sh gradlew clean
        '''
    }
}

        stage('Run Tests') {
            when {
                anyOf {
                    branch 'master'
                    expression {
                        env.BRANCH_NAME.contains('feature')
                    }
                }
            }

            steps {
                sh '''
                    cd Chapter08/sample1
                    chmod +x gradlew
                    sh gradlew test
                '''
            }

            post {

                success {
                    echo "tests pass!"
                }

                failure {
                    echo "tests fail!"
                }

                always {
                    sh '''
                        cd Chapter08/sample1
                        chmod +x gradlew
                        sh gradlew jacocoTestReport || true
                    '''
                }
            }
        }

        stage('Code Coverage') {

            when {
                branch 'master'
            }

            steps {
                sh '''
                    cd Chapter08/sample1
                    chmod +x gradlew
                    sh gradlew jacocoTestCoverageVerification
                '''
            }
        }

        stage('Checkstyle') {

            when {
                anyOf {
                    branch 'master'

                    expression {
                        env.BRANCH_NAME.contains('feature')
                    }
                }
            }

            steps {
                sh '''
                    cd Chapter08/sample1
                    chmod +x gradlew
                    sh gradlew checkstyleMain
                '''
            }

            post {
                always {
                    publishHTML(target: [
                        reportDir: 'Chapter08/sample1/build/reports/checkstyle',
                        reportFiles: 'main.html',
                        reportName: 'Checkstyle Report'
                    ])
                }
            }
        }
    }

    post {

        success {
            echo "Pipeline completed successfully."
        }

        failure {
            echo "Pipeline failed."
        }

        always {
            sh """
                cd Chapter08/sample1
                sh gradlew jacocoTestReport --info
                sh gradlew tasks --all | grep -i jacoco
                
            """

            publishHTML(target: [
                reportDir: 'Chapter08/sample1/build/reports/jacoco/test/html',
                reportFiles: 'index.html',
                reportName: 'JaCoCo Report'
            ])

            echo "Branch: ${env.BRANCH_NAME}"

        }
    }
}
